    /// The player resigns the game, conceding victory to the opponent.
    Resign,
}

impl Display for GameAction {
    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
        match self {
            GameAction::Swap => write!(f, "Swap"),
