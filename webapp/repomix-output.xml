        const props = sessionGamePageMock.mock.calls[0][0];
        const result = await props.start();

        expect(putConfig).toHaveBeenCalledWith({
            size: 9,
            hvb_starter: "bot",
            bot_id: "mcts_bot",
            hvh_starter: "player0",
