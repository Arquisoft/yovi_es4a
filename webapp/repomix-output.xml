  { value: "winRate",     label: "% Partidas ganadas", icon: <TrophyOutlined /> },
  { value: "gamesWon",    label: "Partidas ganadas",    icon: <RiseOutlined /> },
  { value: "gamesPlayed", label: "Partidas jugadas",    icon: <PlayCircleOutlined /> },
];

