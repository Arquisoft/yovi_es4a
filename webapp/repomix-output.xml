      title: 'Partidas',
      dataIndex: 'gamesPlayed',
      key: 'gamesPlayed',
      align: 'center' as const,
      render: (val: number) => (
        <Tag color={sortBy === "gamesPlayed" ? "purple" : "default"}>{val}</Tag>
      ),
    },
    {
      title: 'Movimientos',
      dataIndex: 'totalMoves',
      key: 'totalMoves',
      align: 'center' as const,
      render: (val: number) => (
        <Tooltip title="Movimientos realizados en partidas ganadas">
