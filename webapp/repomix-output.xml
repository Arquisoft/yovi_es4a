    {
      title: '% Victoria',
      dataIndex: 'winRate',
      key: 'winRate',
      align: 'center' as const,
      render: (val: number) => (
        <Tooltip title={`${val}% de victorias`}>
          <Progress percent={val} size="small" status="active" format={(percent) => `${percent}%`} />
        </Tooltip>
      ),
    },
    {
      title: 'Victorias',
      dataIndex: 'gamesWon',
      key: 'gamesWon',
      align: 'center' as const,
      render: (val: number) => (
        <Tag color={sortBy === "gamesWon" ? "geekblue" : "default"}>{val}</Tag>
      ),
