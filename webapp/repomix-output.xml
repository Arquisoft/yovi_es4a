export async function deleteHvhGame(gameId: string): Promise<{ deleted: boolean }> {
  return http<{ deleted: boolean }>(`/api/v1/hvh/games/${encodeURIComponent(gameId)}`, {
    method: "DELETE",
    headers: buildHeaders(),
