{
  "name": "webapp",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest --watch",
    "test:e2e:run": "cucumber-js --tags 'not @skip' --import test/e2e/support/setup.mjs --import 'test/e2e/steps/**/*.mjs' test/e2e/features --format progress",
    "test:e2e:install-browsers": "npx playwright install",
    "start:all": "concurrently \"npm run dev\" \"npm --prefix ../users start\"",
    "start:ci": "vite",
    "test:e2e": "start-server-and-test start:ci http://localhost:5173 test:e2e:run",
    "test:e2e:dev": "start-server-and-test start:all http://localhost:5173 test:e2e:run",
    "test:e2e:headed": "cross-env E2E_HEADLESS=false start-server-and-test start:all http://localhost:5173 test:e2e:run",
    "test:e2e:slow": "cross-env E2E_HEADLESS=false E2E_SLOW_MO=800 start-server-and-test start:all http://localhost:5173 test:e2e:run",
    "test:e2e:debug": "cross-env E2E_HEADLESS=false E2E_SLOW_MO=800 E2E_DEVTOOLS=true start-server-and-test start:all http://localhost:5173 test:e2e:run",
    "test:e2e:docker": "cross-env E2E_HEADLESS=false E2E_BASE_URL=http://localhost cucumber-js --import test/e2e/support/setup.mjs --import 'test/e2e/steps/**/*.mjs' test/e2e/features"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/material": "^7.3.8",
    "antd": "^6.3.2",
    "lottie-react": "^2.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hexgrid": "^2.0.1",
    "react-router-dom": "^6.30.3"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^12.4.0",
    "@eslint/js": "^9.39.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^14.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.10.1",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.0.16",
    "concurrently": "^8.2.0",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^22.1.0",
    "playwright": "^1.43.0",
    "start-server-and-test": "^2.1.3",
    "ts-node": "^10.9.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vitest": "^4.0.16",
    "vitest-sonar-reporter": "^3.0.0"
  }
}
